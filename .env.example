PORT=4242
APP_URL=http://localhost:4242
EXTENSION_API_BASE=http://localhost:4242

# Use a restricted key in production. For local testing, Stripe sandbox keys are fine.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Create a recurring Price for $12/year in Stripe and paste the price ID here.
STRIPE_PRICE_ID=price_...

# Local dev default is intentionally in-memory. Use a database before production.
FREE_CHECK_LIMIT=10
